<!DOCTYPE html>
<html>
<head>
    <title>Frameset Example</title>
</head>

<frameset cols="30%,70%">
    <frame src="menu.html" name="leftframe">
    <frame src="home.html" name="rightframe">
</frameset>

</html>

<!DOCTYPE html>
<html>
<head>
    <title>Menu</title>
</head>

<body bgcolor="lightblue">
    <h2>Menu</h2>

    <a href="home.html" target="rightframe">Home</a><br><br>

    <a href="about.html" target="rightframe">About</a>
</body>
</html>
<!DOCTYPE html>
<html>
<head>
    <title>Home</title>
</head>

<body bgcolor="white">
    <h1>Welcome</h1>
    <p>This is the Home Page.</p>
</body>
</html>
<!DOCTYPE html>
<html>
<head>
    <title>About</title>
</head>

<body bgcolor="lightyellow">
    <h1>About Page</h1>
    <p>This is a simple Frameset example created using HTML.</p>
</body>
</html>
